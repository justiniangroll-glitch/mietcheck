        .logo { font-size: 18px; letter-spacing: 4px; text-transform: uppercase; font-weight: 600; color: white; margin-left: 10px; }
        .container { max-width: 700px; margin: 0 auto; padding: 48px 20px 80px; }
        h1 { font-size: 28px; font-weight: 700; margin-bottom: 32px; }
        h2 { font-size: 16px; font-weight: 700; margin: 28px 0 8px; }
        p { font-size: 15px; color: #444; line-height: 1.7; margin-bottom: 8px; }
        a { color: #1a2a4a; }
        .footer { padding: 28px 16px; text-align: center; background: #1a2a4a; margin-top: 60px; }
        .footer p { font-size: 11px; color: rgba(255,255,255,0.4); line-height: 1.8; }
        .footer a { color: rgba(255,255,255,0.4); }
    </style>
</head>
